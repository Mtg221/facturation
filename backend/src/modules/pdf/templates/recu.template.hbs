<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, sans-serif; font-size: 12px; color: #1a1a1a; }
  .container { max-width: 560px; margin: 0 auto; padding: 32px; }
  .header { text-align: center; border-bottom: 3px solid #1e3a5f; padding-bottom: 20px; margin-bottom: 24px; }
  .header h1 { font-size: 24px; color: #1e3a5f; letter-spacing: 3px; }
  .header .subtitle { font-size: 13px; color: #666; margin-top: 4px; }
  .company { text-align: center; font-size: 11px; color: #555; margin-bottom: 20px; }
  .recu-info { display: flex; justify-content: space-between; margin-bottom: 24px; background: #f8f9fa; padding: 16px; border-radius: 6px; }
  .info-group label { font-size: 9px; text-transform: uppercase; letter-spacing: 1px; color: #888; display: block; margin-bottom: 3px; }
  .info-group .val { font-weight: 600; font-size: 13px; }
  .amount-box { background: #1e3a5f; color: white; text-align: center; padding: 20px; border-radius: 8px; margin-bottom: 24px; }
  .amount-box .label { font-size: 11px; opacity: 0.8; text-transform: uppercase; letter-spacing: 1px; }
  .amount-box .amount { font-size: 32px; font-weight: 700; margin-top: 6px; }
  .amount-box .words { font-size: 11px; opacity: 0.85; margin-top: 4px; font-style: italic; }
  .details { margin-bottom: 24px; }
  .details table { width: 100%; }
  .details td { padding: 8px 0; border-bottom: 1px solid #eee; }
  .details td:first-child { color: #666; }
  .details td:last-child { text-align: right; font-weight: 500; }
  .footer { text-align: center; border-top: 1px solid #eee; padding-top: 16px; font-size: 10px; color: #aaa; }
  .stamp { border: 2px dashed #ccc; height: 70px; width: 160px; margin: 16px auto; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #bbb; font-size: 10px; }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>REÇU DE PAIEMENT</h1>
    <div class="subtitle">Confirmation de paiement</div>
  </div>

  <div class="company">
    <strong>{{company.nom}}</strong> &nbsp;|&nbsp; {{company.adresse}}
    {{#if company.telephone}}&nbsp;|&nbsp; {{company.telephone}}{{/if}}
  </div>

  <div class="recu-info">
    <div class="info-group">
      <label>Date de paiement</label>
      <div class="val">{{formatDate paiement.datePaiement}}</div>
    </div>
    <div class="info-group">
      <label>Mode de paiement</label>
      <div class="val">{{paiement.mode}}</div>
    </div>
    <div class="info-group">
      <label>Facture N°</label>
      <div class="val">{{paiement.facture.numero}}</div>
    </div>
  </div>

  <div class="amount-box">
    <div class="label">Montant reçu</div>
    <div class="amount">{{formatMoney paiement.montant}} FCFA</div>
  </div>

  <div class="details">
    <table>
      <tr>
        <td>Client</td>
        <td>{{paiement.facture.client.nom}}</td>
      </tr>
      {{#if paiement.reference}}
      <tr>
        <td>Référence</td>
        <td>{{paiement.reference}}</td>
      </tr>
      {{/if}}
      {{#if paiement.numeroCheque}}
      <tr>
        <td>N° Chèque</td>
        <td>{{paiement.numeroCheque}}</td>
      </tr>
      {{/if}}
      {{#if paiement.banque}}
      <tr>
        <td>Banque</td>
        <td>{{paiement.banque}}</td>
      </tr>
      {{/if}}
      {{#if paiement.recuPar}}
      <tr>
        <td>Reçu par</td>
        <td>{{paiement.recuPar}}</td>
      </tr>
      {{/if}}
      {{#if paiement.payePar}}
      <tr>
        <td>Payé par</td>
        <td>{{paiement.payePar}}</td>
      </tr>
      {{/if}}
    </table>
  </div>

  <div class="stamp">Cachet &amp; Signature</div>

  <div class="footer">
    <p>Ce reçu confirme la réception du paiement indiqué ci-dessus.</p>
    <p>Généré le {{generatedAt}}</p>
  </div>
</div>
</body>
</html>
